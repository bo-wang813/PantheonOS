{
    "$schema": "https://pantheon.dev/schemas/mcp.json",
    "version": "1.0.0",
    // ===== MCP Server Configuration =====
    // Model Context Protocol servers provide extended tool capabilities
    // Each server is exposed at an independent URL path: http://localhost:3000/mcp/{server_name}
    //
    // Two types are supported:
    // - stdio: Local subprocess with STDIO transport (Endpoint manages lifecycle)
    // - http: Connect to existing remote HTTP endpoint (no process management)
    // List of MCP servers to auto-start when Endpoint starts
    "auto_start": [],
    "servers": {
        // === Example 1: Local STDIO Server (Endpoint managed startup) ===
        "biomcp": {
            "type": "stdio",
            "command": "uv run --with biomcp-python biomcp run",
            "env": {
                // Environment variable reference syntax: ${ENV_VAR_NAME}
                // "NCI_API_KEY": "${NCI_API_KEY}"
            },
            "description": "BioMCP - Bioinformatics tools"
        },
        "context7": {
            "type": "stdio",
            "command": "npx -y @upstash/context7-mcp",
            "description": "Context7 - Documentation query tools"
        }
        // === Example 2: Remote HTTP Endpoint (Already running service) ===
        // "web_search": {
        //   "type": "http",
        //   "uri": "https://api.example.com/mcp",
        //   "description": "Web Search - Remote MCP service"
        // }
    }
}